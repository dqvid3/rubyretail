<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blackPart">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/white"
        android:elevation="8dp"
        app:cardCornerRadius="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/redPart"
                android:paddingHorizontal="50dp"
                android:text="Impostazioni"
                android:textAlignment="center"
                android:textColor="@color/white"
                android:textSize="35sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/your_cards"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginVertical="35dp"
                android:backgroundTint="@color/redPart"
                android:drawableLeft="@drawable/ic_card"
                android:paddingHorizontal="40dp"
                android:paddingVertical="15dp"
                android:text="Le tue carte"
                app:cornerRadius="25dp" />

            <Button
                android:id="@+id/your_addresses"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:backgroundTint="@color/redPart"
                android:drawableLeft="@drawable/ic_location"
                android:paddingHorizontal="40dp"
                android:paddingVertical="15dp"
                android:text="I tuoi indirizzi"
                app:cornerRadius="25dp" />

            <Button
                android:id="@+id/logoutButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginVertical="35dp"
                android:backgroundTint="@color/redPart"
                android:drawableLeft="@drawable/ic_logout"
                android:paddingHorizontal="40dp"
                android:paddingVertical="15dp"
                android:text="Logout"
                app:cornerRadius="25dp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
